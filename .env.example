TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=+911234567890
TELEGRAM_BOT_TOKEN=
TELEGRAM_SESSION_NAME=telegram-signal-copier
TELEGRAM_USERNAME=@yourusername
TELEGRAM_USER_ID=
TELEGRAM_FIRST_NAME=
TELEGRAM_SOURCES=My Signals Group,Gold VIP

# User account mode needs TELEGRAM_API_ID and TELEGRAM_API_HASH from my.telegram.org.
# TELEGRAM_BOT_TOKEN is optional and only useful for bot-based access.

# ── MT5 Account ──────────────────────────────────────────────────────────────
# Your MetaTrader 5 account credentials (used for analytics & P&L reporting)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

OPENAI_API_KEY=
OPENAI_MODEL=Llama-4-Maverick-17B-128E-Instruct
OPENAI_BASE_URL=https://api.sambanova.ai/v1

# Optional AI provider fallbacks (configure only those you will actually use)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4

NVIDIA_CLOUDNAME=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://api.ngc.nvidia.com/v2

CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.net/v1

# AI tuning and fallback behavior
AI_MAX_REQUESTS_PER_MINUTE=60
AI_PROVIDER_COOLDOWN_SECONDS=60
AI_PROVIDER_MAX_COOLDOWN_SECONDS=3600
AI_CACHE_TTL_SECONDS=300

# Groq API
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.ai/v1

MINIMUM_CONFIDENCE=0.70
APPROVAL_REQUIRED_BELOW=0.85
DEFAULT_VOLUME=0.10
ALLOWED_SYMBOLS=XAUUSD,EURUSD,GBPUSD,USDJPY
DRY_RUN=true
POLL_INTERVAL_SECONDS=2.0

# Frozen Windows builds store writable runtime data here by default:
# %APPDATA%\TelegramSignalCopier
# Optional override:
# TELEGRAM_SIGNAL_COPIER_HOME=C:\TelegramSignalCopierData

# Optional override. Default points to MetaTrader common files bridge folder.
# MT5_BRIDGE_DIR=C:\Users\YOUR_USER\AppData\Roaming\MetaQuotes\Terminal\Common\Files\TelegramSignalCopierBridge