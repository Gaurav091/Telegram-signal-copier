TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=+911234567890
TELEGRAM_BOT_TOKEN=
TELEGRAM_SESSION_NAME=telegram-signal-copier
TELEGRAM_USERNAME=@yourusername
TELEGRAM_USER_ID=
TELEGRAM_FIRST_NAME=
TELEGRAM_SOURCES=My Signals Group,Gold VIP

# User account mode needs TELEGRAM_API_ID and TELEGRAM_API_HASH from my.telegram.org.
# TELEGRAM_BOT_TOKEN is optional and only useful for bot-based access.

OPENAI_API_KEY=
OPENAI_MODEL=Llama-4-Maverick-17B-128E-Instruct
OPENAI_BASE_URL=https://api.sambanova.ai/v1

MINIMUM_CONFIDENCE=0.70
APPROVAL_REQUIRED_BELOW=0.85
DEFAULT_VOLUME=0.10
ALLOWED_SYMBOLS=XAUUSD,EURUSD,GBPUSD,USDJPY
DRY_RUN=true
POLL_INTERVAL_SECONDS=2.0

# Optional override. Default points to MetaTrader common files bridge folder.
# MT5_BRIDGE_DIR=C:\Users\YOUR_USER\AppData\Roaming\MetaQuotes\Terminal\Common\Files\TelegramSignalCopierBridge